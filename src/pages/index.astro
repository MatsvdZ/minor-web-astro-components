---
import MainLayout from "../layouts/MainLayout.astro"
import Button from "../components/Button.astro"
import Artwork from "../components/Artwork.astro"

const res = await fetch('https://api.artic.edu/api/v1/artworks/search?q=cat&limit=9&page=10&fields=id,title,image_id,color')
const artworksData = await res.json()
const imageBase = 'https://www.artic.edu/iiif/2'
const imageEnd = '/full/843,/0/default.jpg'

console.log(artworksData.data)
---

<MainLayout title="Jad is gek">
	<h1>Cats ofzo</h1>
	<Button href="/dog" text="Dogs zijn te gek" />
	{artworksData.data.map(artwork => {
		return (
			<Artwork imageUrl={`${imageBase}/${artwork.image_id}${imageEnd}`} title={artwork.title} />
			// <article>
			// 	<img src={`${imageBase}/${artwork.image_id}${imageEnd}`} alt="{artwork.title}" />
			// 	<h2>{artwork.title}</h2>
			// </article>
		)
	})}
</MainLayout>